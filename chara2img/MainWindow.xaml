<Window x:Class="chara2img.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:chara2img"
        xmlns:vm="clr-namespace:chara2img.ViewModels"
        mc:Ignorable="d"
        Title="Chara2IMG - ComfyUI Runner" Height="700" Width="1000"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Grid>
        <TabControl Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <!-- Settings Tab -->
            <TabItem Header="Settings">
                <Grid Margin="20" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <Label Content="RunPod API Key:" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                        <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15"/>

                        <Label Content="Endpoint ID:" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                        <TextBox Text="{Binding EndpointId, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15"/>

                        <Label Content="Output Folder:" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                        <Grid Margin="0,5,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding OutputFolder}" IsReadOnly="True" Margin="0,0,10,0"/>
                            <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseFolderCommand}" Padding="15,5"/>
                        </Grid>
                    </StackPanel>

                    <TextBlock Grid.Row="3" 
                               Text="Configure your RunPod serverless ComfyUI endpoint credentials above." 
                               VerticalAlignment="Bottom" 
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               TextWrapping="Wrap"/>
                </Grid>
            </TabItem>

            <!-- Workflow Tab -->
            <TabItem Header="Workflow">
                <Grid Margin="20" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="Paste your ComfyUI workflow JSON or load from a file:"
                               Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Load from File..." 
                                Command="{Binding LoadWorkflowCommand}"
                                Padding="15,8"
                                Margin="0,0,10,0"/>
                        <Button Content="Validate JSON" 
                                Command="{Binding ValidateWorkflowCommand}"
                                Padding="15,8"
                                Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding WorkflowFilePath}"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   VerticalAlignment="Center"
                                   FontStyle="Italic"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <Border Grid.Row="2" 
                            BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" 
                            BorderThickness="1"
                            Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                        <TextBox Text="{Binding WorkflowJson, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Padding="5"
                                 Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                 Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                    </Border>

                    <StackPanel Grid.Row="3" Margin="0,10,0,0">
                        <TextBlock Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   TextWrapping="Wrap">
                            <Run Text="💡 Tip: Export your ComfyUI workflow as JSON (API format) and paste it here, or save it as request.json and load it using the button above."/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Run Tab -->
            <TabItem Header="Run">
                <Grid Margin="20" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="▶ Run ComfyUI Job" 
                                Command="{Binding RunJobCommand}"
                                Padding="20,10"
                                FontWeight="SemiBold"
                                Margin="0,0,10,0"/>
                        <Border Background="{DynamicResource {x:Static SystemColors.InfoBrushKey}}"
                                Padding="10,5"
                                CornerRadius="3"
                                Visibility="{Binding HasWorkflow, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <TextBlock Text="⚠ No workflow loaded"
                                       Foreground="{DynamicResource {x:Static SystemColors.InfoTextBrushKey}}"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Grid.Row="1" 
                               Text="{Binding StatusMessage}" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                               Margin="0,0,0,15"/>

                    <ListView Grid.Row="2" 
                              x:Name="JobsListView"
                              ItemsSource="{Binding Jobs}"
                              SelectedItem="{Binding SelectedJob}"
                              Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                              Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                              MouseDoubleClick="JobsListView_MouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Job ID" Width="200" DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Header="Status" Width="100" DisplayMemberBinding="{Binding Status}"/>
                                <GridViewColumn Header="Created" Width="150" DisplayMemberBinding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"/>
                                <GridViewColumn Header="Completed" Width="150" DisplayMemberBinding="{Binding CompletedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <GridSplitter Grid.Row="3" 
                                  Height="5" 
                                  HorizontalAlignment="Stretch" 
                                  Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                  Margin="0,5"/>

                    <!-- Status Response Viewer -->
                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5,0,10">
                            <TextBlock Text="Latest Status Response" 
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,15,0"/>
                            <Button Content="🔄 Refresh" 
                                    Command="{Binding RefreshJobStatusCommand}"
                                    Padding="10,5"
                                    Margin="0,0,10,0"/>
                            <Button Content="{Binding IsStatusResponseExpanded, Converter={StaticResource ExpandCollapseTextConverter}}" 
                                    Command="{Binding ToggleStatusResponseCommand}"
                                    Padding="10,5"/>
                        </StackPanel>

                        <Border Grid.Row="1" 
                                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" 
                                BorderThickness="1"
                                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                <TextBox Text="{Binding StatusResponsePreview, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         Padding="10"
                                         BorderThickness="0"
                                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Output Tab -->
            <TabItem Header="Output">
                <Grid Margin="20" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Image Source="{Binding CurrentImage}" 
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </ScrollViewer>
                    <TextBlock Text="Generated images will appear here" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               FontSize="16"
                               Visibility="{Binding CurrentImage, Converter={StaticResource NullToVisibilityConverter}}"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
