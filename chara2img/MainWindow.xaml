<Window x:Class="chara2img.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:chara2img"
        xmlns:vm="clr-namespace:chara2img.ViewModels"
        mc:Ignorable="d"
        Title="Chara2IMG - ComfyUI Runner" Height="700" Width="1000"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <local:ExpandCollapseTextConverter x:Key="ExpandCollapseTextConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
        <local:InputTypeToVisibilityConverter x:Key="InputTypeToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <TabControl Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">

            <!-- Workflow Tab -->
            <TabItem Header="Workflow">
                <Grid Margin="20" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="Paste your ComfyUI workflow JSON or load from a file:"
                               Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Load from File..." 
                                Command="{Binding LoadWorkflowCommand}"
                                Padding="15,8"
                                Margin="0,0,10,0"/>
                        <Button Content="Validate JSON" 
                                Command="{Binding ValidateWorkflowCommand}"
                                Padding="15,8"
                                Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding WorkflowFilePath}"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   VerticalAlignment="Center"
                                   FontStyle="Italic"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <Border Grid.Row="2" 
                            BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" 
                            BorderThickness="1"
                            Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                        <TextBox x:Name="WorkflowTextBox"
                                 Text="{Binding WorkflowJson, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Padding="5"
                                 Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                 Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                    </Border>

                    <StackPanel Grid.Row="3" Margin="0,10,0,0">
                        <TextBlock Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   TextWrapping="Wrap">
                            <Run Text="💡 Tip: Export your ComfyUI workflow as JSON (API format) and paste it here, or save it as request.json and load it using the button above."/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Input Tab (moved after Workflow) -->
            <TabItem Header="Input">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">

                        <!-- Config Section -->
                        <GroupBox Header="Config" Margin="0,0,0,15" Padding="10">
                            <ItemsControl ItemsSource="{Binding WorkflowInputs[Config]}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" Margin="0,5" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <!-- Model Section -->
                        <GroupBox Header="Model" Margin="0,0,0,15" Padding="10">
                            <ItemsControl ItemsSource="{Binding WorkflowInputs[Model]}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>

                                            <!-- Text Input -->
                                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                         Padding="5"
                                         Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=text}"/>

                                            <!-- Lora List -->
                                            <ItemsControl ItemsSource="{Binding Loras}"
                                             Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=lora_list}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="150"/>
                                                            </Grid.ColumnDefinitions>

                                                            <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding LoraName}" VerticalAlignment="Center" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>

                                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                <Slider Value="{Binding Strength}" Minimum="-2" Maximum="2" Width="80" VerticalAlignment="Center" 
                                                           TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                                                                <TextBox Text="{Binding Strength, StringFormat=F2}" Width="50" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <!-- Image Section -->
                        <GroupBox Header="Image" Margin="0,0,0,15" Padding="10">
                            <ItemsControl ItemsSource="{Binding WorkflowInputs[Image]}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>

                                            <!-- Number Pair (Width x Height) -->
                                            <Grid Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=number_pair}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="100"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="{Binding Label1}" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                                                <TextBox Grid.Column="1" Text="{Binding Value1, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox"/>
                                                <TextBlock Grid.Column="2" Text="×" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Label2}" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                                                <TextBox Grid.Column="4" Text="{Binding Value2, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox"/>
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <!-- Character Section -->
                        <GroupBox Header="Character" Margin="0,0,0,15" Padding="10">
                            <ItemsControl ItemsSource="{Binding WorkflowInputs[Character]}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" Margin="0,5" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontStyle="Italic"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <!-- Costume Section -->
                        <GroupBox Header="Costume" Margin="0,0,0,15" Padding="10">
                            <ItemsControl ItemsSource="{Binding WorkflowInputs[Costume]}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" Margin="0,5" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontStyle="Italic"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <!-- Pose Section -->
                        <GroupBox Header="Pose" Margin="0,0,0,15" Padding="10">
                            <ItemsControl ItemsSource="{Binding WorkflowInputs[Pose]}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" Margin="0,5" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontStyle="Italic"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <!-- Prompt Section (moved before Detailer) -->
                        <GroupBox Header="Prompt" Margin="0,0,0,15" Padding="10">
                            <ItemsControl ItemsSource="{Binding WorkflowInputs[Prompt]}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>

                                            <!-- Multiline Text -->
                                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinHeight="100"
                                         MaxHeight="200"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="5"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=multiline}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <!-- Detailer Section -->
                        <GroupBox Header="Detailer" Margin="0,0,0,15" Padding="10">
                            <ItemsControl ItemsSource="{Binding WorkflowInputs[Detailer]}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" Margin="0,5" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontStyle="Italic"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Run Tab -->
            <TabItem Header="Run">
                <Grid Margin="20" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="▶ Run ComfyUI Job" 
                                Command="{Binding RunJobCommand}"
                                Padding="20,10"
                                FontWeight="SemiBold"
                                Margin="0,0,10,0"/>
                        <Border Background="{DynamicResource {x:Static SystemColors.InfoBrushKey}}"
                                Padding="10,5"
                                CornerRadius="3"
                                Visibility="{Binding HasWorkflow, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <TextBlock Text="⚠ No workflow loaded"
                                       Foreground="{DynamicResource {x:Static SystemColors.InfoTextBrushKey}}"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Grid.Row="1" 
                               Text="{Binding StatusMessage}" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                               Margin="0,0,0,15"/>

                    <ListView Grid.Row="2" 
                              x:Name="JobsListView"
                              ItemsSource="{Binding Jobs}"
                              SelectedItem="{Binding SelectedJob}"
                              Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                              Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                              MouseDoubleClick="JobsListView_MouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Job ID" Width="200" DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Header="Status" Width="100" DisplayMemberBinding="{Binding Status}"/>
                                <GridViewColumn Header="Created" Width="150" DisplayMemberBinding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"/>
                                <GridViewColumn Header="Completed" Width="150" DisplayMemberBinding="{Binding CompletedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"/>
                                <GridViewColumn Header="Duration" Width="100" DisplayMemberBinding="{Binding Duration}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <GridSplitter Grid.Row="3" 
                                  Height="5" 
                                  HorizontalAlignment="Stretch" 
                                  Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                  Margin="0,5"/>

                    <!-- Status Response Viewer -->
                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5,0,10">
                            <TextBlock Text="Latest Status Response" 
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,15,0"/>
                            <Button Content="🔄 Refresh" 
                                    Command="{Binding RefreshJobStatusCommand}"
                                    Padding="10,5"
                                    Margin="0,0,10,0"/>
                            <Button Content="{Binding IsStatusResponseExpanded, Converter={StaticResource ExpandCollapseTextConverter}}" 
                                    Command="{Binding ToggleStatusResponseCommand}"
                                    Padding="10,5"/>
                        </StackPanel>

                        <Border Grid.Row="1" 
                                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" 
                                BorderThickness="1"
                                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                <TextBox Text="{Binding StatusResponsePreview, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         Padding="10"
                                         BorderThickness="0"
                                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Output Tab -->
            <TabItem Header="Output">
                <Grid Margin="20" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="💡 Tip: Use mouse wheel to zoom, click and drag to pan" 
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               Margin="0,0,0,10"/>

                    <!-- Gallery View -->
                    <Grid Grid.Row="1" Visibility="{Binding IsGalleryView, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding CurrentImages}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.ShowImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Margin="10"
                                                Padding="0"
                                                BorderThickness="2"
                                                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                                Background="Transparent"
                                                Cursor="Hand">
                                            <Image Source="{Binding}" 
                                                Width="250" 
                                                Height="250"
                                                Stretch="Uniform"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock Text="Generated images will appear here. Select a completed job from the Run tab to view its images." 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                    FontSize="16"
                                    TextAlignment="Center"
                                    Visibility="{Binding CurrentImages.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                    </Grid>

                    <!-- Full Image View -->
                    <Grid Grid.Row="1" Visibility="{Binding IsGalleryView, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                            <Button Content="💾 Save As..." 
                                    Command="{Binding SaveImageAsCommand}"
                                    Padding="15,8"
                                    FontSize="14"
                                    Margin="0,0,10,0"/>
                            <Button Content="✕ Close" 
                                    Command="{Binding CloseImageCommand}"
                                    Padding="15,8"
                                    FontSize="14"
                                    FontWeight="Bold"/>
                        </StackPanel>

                        <Border Grid.Row="1" 
                                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" 
                                BorderThickness="1">
                            <ScrollViewer x:Name="ImageScrollViewer"
                                          HorizontalScrollBarVisibility="Auto" 
                                          VerticalScrollBarVisibility="Auto"
                                          PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                                          SizeChanged="ImageScrollViewer_SizeChanged">
                                <Image x:Name="OutputImage"
                                       Source="{Binding CurrentImage, NotifyOnTargetUpdated=True}" 
                                       Stretch="None"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       MouseLeftButtonDown="OutputImage_MouseLeftButtonDown"
                                       MouseLeftButtonUp="OutputImage_MouseLeftButtonUp"
                                       MouseMove="OutputImage_MouseMove"
                                       Cursor="{Binding ElementName=OutputImage, Path=Tag}"
                                       TargetUpdated="OutputImage_TargetUpdated">
                                    <Image.LayoutTransform>
                                        <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                                    </Image.LayoutTransform>
                                </Image>
                            </ScrollViewer>
                        </Border>

                        <TextBlock Grid.Row="1"
                                   Text="💡 Use mouse wheel to zoom, click and drag to pan" 
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,0,10"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="Settings">
                <Grid Margin="20" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <Label Content="Runpod API Key:" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                        <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15"/>

                        <Label Content="Endpoint ID:" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                        <TextBox Text="{Binding EndpointId, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15"/>

                        <Label Content="Output Folder:" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                        <Grid Margin="0,5,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding OutputFolder}" IsReadOnly="True" Margin="0,0,10,0"/>
                            <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseFolderCommand}" Padding="15,5" Margin="0,0,10,0"/>
                            <Button Grid.Column="2" Content="Open Folder" Command="{Binding OpenImageFolderCommand}" Padding="15,5"/>
                        </Grid>
                    </StackPanel>

                    <TextBlock Grid.Row="3" 
                               Text="Configure your Runpod serverless ComfyUI endpoint credentials above." 
                               VerticalAlignment="Bottom" 
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               TextWrapping="Wrap"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
