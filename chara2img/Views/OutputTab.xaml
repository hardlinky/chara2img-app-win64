<UserControl x:Class="chara2img.Views.OutputTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:chara2img"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Focusable="True"
             PreviewKeyDown="OutputTab_PreviewKeyDown">
    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Grid Margin="20" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="💡 Tip: Use mouse wheel to zoom, click and drag to pan, arrow keys to navigate" 
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                   Margin="0,0,0,10"/>

        <!-- Gallery View -->
        <Grid Grid.Row="1" Visibility="{Binding IsGalleryView, Converter={StaticResource BoolToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding CurrentImages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.ShowImageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Margin="10"
                                    Padding="0"
                                    BorderThickness="2"
                                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                    Background="Transparent"
                                    Cursor="Hand">
                                <Image Source="{Binding}" 
                                    Width="250" 
                                    Height="250"
                                    Stretch="Uniform"/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <TextBlock Text="Generated images will appear here. Select a completed job from the Run tab to view its images." 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                        FontSize="16"
                        TextAlignment="Center"
                        Visibility="{Binding CurrentImages.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
        </Grid>

        <!-- Full Image View -->
        <Grid Grid.Row="1" Visibility="{Binding IsGalleryView, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                <Button Content="💾 Save As..." 
                        Command="{Binding SaveImageAsCommand}"
                        Padding="15,8"
                        FontSize="14"
                        Margin="0,0,10,0"/>
                <Button Content="✕ Close" 
                        Command="{Binding CloseImageCommand}"
                        Padding="15,8"
                        FontSize="14"
                        FontWeight="Bold"/>
            </StackPanel>

            <Border Grid.Row="1" 
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" 
                    BorderThickness="1">
                <ScrollViewer x:Name="ImageScrollViewer"
                              HorizontalScrollBarVisibility="Auto" 
                              VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                              SizeChanged="ImageScrollViewer_SizeChanged">
                    <Image x:Name="OutputImage"
                           Source="{Binding CurrentImage, NotifyOnTargetUpdated=True}" 
                           Stretch="None"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           MouseLeftButtonDown="OutputImage_MouseLeftButtonDown"
                           MouseLeftButtonUp="OutputImage_MouseLeftButtonUp"
                           MouseMove="OutputImage_MouseMove"
                           Cursor="{Binding ElementName=OutputImage, Path=Tag}"
                           TargetUpdated="OutputImage_TargetUpdated">
                        <Image.LayoutTransform>
                            <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                        </Image.LayoutTransform>
                    </Image>
                </ScrollViewer>
            </Border>

            <TextBlock Grid.Row="1"
                       Text="💡 Use mouse wheel to zoom, click and drag to pan, arrow keys to navigate" 
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,10"/>
        </Grid>
    </Grid>
</UserControl>