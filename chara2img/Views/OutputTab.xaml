<UserControl x:Class="chara2img.Views.OutputTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:chara2img"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Focusable="True"
             PreviewKeyDown="OutputTab_PreviewKeyDown">
    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
        <local:ImageIndexConverter x:Key="ImageIndexConverter"/>
    </UserControl.Resources>
    
    <Grid>
        <!-- Normal View -->
        <Grid Margin="20" Background="{DynamicResource WindowBackgroundBrush}"
              Visibility="{Binding IsFullscreen, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Gallery View -->
            <Grid Grid.Row="1" Visibility="{Binding IsGalleryView, Converter={StaticResource BoolToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource WindowBackgroundBrush}">
                    <ItemsControl ItemsSource="{Binding CurrentImages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.ShowImageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="10"
                                        Padding="0"
                                        BorderThickness="2"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        Background="Transparent"
                                        Cursor="Hand">
                                    <Image Source="{Binding}" 
                                        Width="250" 
                                        Height="250"
                                        Stretch="Uniform"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <TextBlock Text="Generated images will appear here. Select a completed job from the Run tab to view its images." 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            FontSize="16"
                            TextAlignment="Center"
                            Visibility="{Binding CurrentImages.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
            </Grid>

            <!-- Full Image View -->
            <Grid Grid.Row="1" Visibility="{Binding IsGalleryView, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Bar with Tip and Buttons -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Navigation Tip (Bottom Left of Top Bar) -->
                    <TextBlock Grid.Column="0"
                               Text="💡 Tip: Use mouse wheel to zoom, click and drag to pan, arrow keys to navigate, F11 for fullscreen" 
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Bottom"
                               HorizontalAlignment="Left"/>
                    
                    <!-- Buttons (Top Right) -->
                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <Button Content="💾 Save As..." 
                                Command="{Binding SaveImageAsCommand}"
                                Padding="15,8"
                                FontSize="14"
                                Margin="0,0,10,0"/>
                        <Button Content="✕ Close" 
                                Command="{Binding CloseImageCommand}"
                                Padding="15,8"
                                FontSize="14"
                                FontWeight="Bold"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="1"
                        Background="{DynamicResource ControlBackgroundBrush}">
                    <ScrollViewer x:Name="ImageScrollViewer"
                                  HorizontalScrollBarVisibility="Auto" 
                                  VerticalScrollBarVisibility="Auto"
                                  Background="{DynamicResource ControlBackgroundBrush}"
                                  PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                                  SizeChanged="ImageScrollViewer_SizeChanged">
                        <Image x:Name="OutputImage"
                               Source="{Binding CurrentImage, NotifyOnTargetUpdated=True}" 
                               Stretch="None"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               MouseLeftButtonDown="OutputImage_MouseLeftButtonDown"
                               MouseLeftButtonUp="OutputImage_MouseLeftButtonUp"
                               MouseMove="OutputImage_MouseMove"
                               Cursor="{Binding ElementName=OutputImage, Path=Tag}"
                               TargetUpdated="OutputImage_TargetUpdated">
                            <Image.LayoutTransform>
                                <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Image.LayoutTransform>
                        </Image>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Image Counter (Top Right - Above Everything) -->
            <TextBlock Grid.Row="0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"
                       Visibility="{Binding IsGalleryView, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <Run>
                    <Run.Text>
                        <MultiBinding Converter="{StaticResource ImageIndexConverter}">
                            <Binding Path="CurrentImage" Mode="OneWay"/>
                            <Binding Path="CurrentImages" Mode="OneWay"/>
                            <Binding Path="SelectedJob" Mode="OneWay"/>
                        </MultiBinding>
                    </Run.Text>
                </Run>
            </TextBlock>
        </Grid>

        <!-- Fullscreen View -->
        <Grid Background="Black"
              Visibility="{Binding IsFullscreen, Converter={StaticResource BoolToVisibilityConverter}}">
            <ScrollViewer x:Name="FullscreenScrollViewer"
                          HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Auto"
                          Background="Black"
                          PreviewMouseWheel="FullscreenScrollViewer_PreviewMouseWheel"
                          SizeChanged="FullscreenScrollViewer_SizeChanged">
                <Image x:Name="FullscreenImage"
                       Source="{Binding CurrentImage}" 
                       Stretch="None"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       MouseLeftButtonDown="FullscreenImage_MouseLeftButtonDown"
                       MouseLeftButtonUp="FullscreenImage_MouseLeftButtonUp"
                       MouseMove="FullscreenImage_MouseMove"
                       Cursor="{Binding ElementName=FullscreenImage, Path=Tag}">
                    <Image.LayoutTransform>
                        <ScaleTransform x:Name="FullscreenScaleTransform" ScaleX="1" ScaleY="1"/>
                    </Image.LayoutTransform>
                </Image>
            </ScrollViewer>

            <!-- Fullscreen Info Overlay (Bottom Right) -->
            <StackPanel HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="20"
                        Opacity="0.8">
                <TextBlock Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="14"
                           TextAlignment="Right"
                           Margin="0,0,0,5">
                    <Run>
                        <Run.Text>
                            <MultiBinding Converter="{StaticResource ImageIndexConverter}">
                                <Binding Path="CurrentImage" Mode="OneWay"/>
                                <Binding Path="CurrentImages" Mode="OneWay"/>
                                <Binding Path="SelectedJob" Mode="OneWay"/>
                            </MultiBinding>
                        </Run.Text>
                    </Run>
                </TextBlock>
                <TextBlock Text="Press F11 or ESC to exit fullscreen"
                           Foreground="White"
                           FontSize="12"
                           TextAlignment="Right"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>