<UserControl x:Class="chara2img.Views.RunTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:chara2img"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:ExpandCollapseTextConverter x:Key="ExpandCollapseTextConverter"/>
        <local:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
        <local:JobActionButtonTooltipConverter x:Key="JobActionButtonTooltipConverter"/>
    </UserControl.Resources>

    <Grid Margin="20" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Command="{Binding RunJobCommand}"
                    Padding="20,10"
                    FontWeight="SemiBold"
                    Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="▶" 
                               Foreground="#00C853"
                               FontSize="14"
                               Margin="0,0,5,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Run ComfyUI Job" 
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Border Background="{DynamicResource AccentBrush}"
                    Padding="10,5"
                    CornerRadius="3"
                    Visibility="{Binding HasWorkflow, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <TextBlock Text="⚠ No workflow loaded"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold"/>
            </Border>
        </StackPanel>

        <ListView Grid.Row="1" 
                  x:Name="JobsListView"
                  ItemsSource="{Binding Jobs}"
                  SelectedItem="{Binding SelectedJob}"
                  Background="{DynamicResource WindowBackgroundBrush}"
                  Foreground="{DynamicResource TextBrush}"
                  MouseDoubleClick="JobsListView_MouseDoubleClick"
                  KeyDown="JobsListView_KeyDown"
                  SelectionMode="Extended">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Job ID" Width="130" DisplayMemberBinding="{Binding Id}"/>
                    <GridViewColumn Header="Worker ID" Width="120" DisplayMemberBinding="{Binding WorkerId}"/>
                    <GridViewColumn Header="Status" Width="70" DisplayMemberBinding="{Binding Status}"/>
                    <GridViewColumn Header="Images" Width="60" DisplayMemberBinding="{Binding ImageCount}"/>
                    <GridViewColumn Header="Created" Width="120" DisplayMemberBinding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"/>
                    <GridViewColumn Header="Completed" Width="120" DisplayMemberBinding="{Binding CompletedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"/>
                    <GridViewColumn Header="Duration" Width="70" DisplayMemberBinding="{Binding Duration}"/>
                    <GridViewColumn Header="Actions" Width="280">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding DataContext.CancelOrRemoveJobCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding Status, Converter={StaticResource JobActionButtonTooltipConverter}}"
                                            Padding="6,3"
                                            Margin="0,0,3,0"
                                            FontSize="11"
                                            MinWidth="70">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="pending">
                                                        <Setter Property="Content">
                                                            <Setter.Value>
                                                                <TextBlock>
                                                                    <Run Text="❌" Foreground="#F44336"/>
                                                                    <Run Text=" Cancel"/>
                                                                </TextBlock>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="in_queue">
                                                        <Setter Property="Content">
                                                            <Setter.Value>
                                                                <TextBlock>
                                                                    <Run Text="❌" Foreground="#F44336"/>
                                                                    <Run Text=" Cancel"/>
                                                                </TextBlock>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="in_progress">
                                                        <Setter Property="Content">
                                                            <Setter.Value>
                                                                <TextBlock>
                                                                    <Run Text="❌" Foreground="#F44336"/>
                                                                    <Run Text=" Cancel"/>
                                                                </TextBlock>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                                <!-- Default content for completed/failed/cancelled/timeout -->
                                                <Setter Property="Content">
                                                    <Setter.Value>
                                                        <TextBlock>
                                                            <Run Text="🗑️" Foreground="#F44336"/>
                                                            <Run Text=" Remove"/>
                                                        </TextBlock>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="📋 Load Inputs" 
                                            Command="{Binding DataContext.LoadJobInputsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="6,3"
                                            Margin="0,0,3,0"
                                            FontSize="11"
                                            ToolTip="Load this job's input values into the Input tab"/>
                                    <Button Content="🔄 Rerun" 
                                            Command="{Binding DataContext.RerunJobCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="6,3"
                                            FontSize="11"
                                            ToolTip="Rerun this job with the same input values"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <GridSplitter Grid.Row="2" 
                      Height="5" 
                      HorizontalAlignment="Stretch" 
                      Background="{DynamicResource ControlBackgroundBrush}"
                      Margin="0,5"/>

        <!-- Status Response Viewer -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5,0,10">
                <TextBlock Text="Latest Status Response" 
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>
                <Button Content="🔄 Refresh" 
                        Command="{Binding RefreshJobStatusCommand}"
                        Padding="10,5"
                        Margin="0,0,10,0"/>
                <Button Content="{Binding IsStatusResponseExpanded, Converter={StaticResource ExpandCollapseTextConverter}}" 
                        Command="{Binding ToggleStatusResponseCommand}"
                        Padding="10,5"/>
            </StackPanel>

            <Border Grid.Row="1" 
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="1"
                    Background="{DynamicResource CodeEditorBackgroundBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TextBox Text="{Binding StatusResponsePreview, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             FontSize="11"
                             Padding="10"
                             BorderThickness="0"
                             Background="{DynamicResource CodeEditorBackgroundBrush}"
                             Foreground="{DynamicResource TextBrush}"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>