<UserControl x:Class="chara2img.Views.InputTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:chara2img"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <local:InputTypeToVisibilityConverter x:Key="InputTypeToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:CollapseIconConverter x:Key="CollapseIconConverter"/>
    </UserControl.Resources>
    
    <Grid Margin="20" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Run Button at the top -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Command="{Binding RunJobCommand}"
                    Padding="20,10"
                    FontWeight="SemiBold"
                    Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="▶" 
                               Foreground="#00C853"
                               FontSize="14"
                               Margin="0,0,5,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Run ComfyUI Job" 
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Border Background="{DynamicResource AccentBrush}"
                    Padding="10,5"
                    CornerRadius="3"
                    Visibility="{Binding HasWorkflow, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <TextBlock Text="⚠ No workflow loaded"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold"/>
            </Border>
        </StackPanel>

        <!-- Scrollable inputs section -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding CategoryViewModels}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="1" 
                                CornerRadius="4" 
                                Margin="0,0,0,10"
                                Background="{DynamicResource WindowBackgroundBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Category Header -->
                                <Grid Grid.Row="0" Background="{DynamicResource AccentBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Category Title (clickable to toggle) -->
                                    <Button Grid.Column="0" 
                                            Command="{Binding DataContext.ToggleCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding CategoryInfo}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="10"
                                            Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding CategoryInfo.IsCollapsed, Converter={StaticResource CollapseIconConverter}}"
                                                       FontFamily="Segoe UI Symbol"
                                                       FontSize="14"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <TextBlock Text="{Binding CategoryInfo.Name}" 
                                                       FontWeight="Bold" 
                                                       FontSize="14"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Reorder Buttons -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="5">
                                        <Button Command="{Binding DataContext.MoveCategoryUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding CategoryInfo}"
                                                Content="▲"
                                                Width="30"
                                                Height="30"
                                                Margin="2"
                                                ToolTip="Move Up"
                                                FontSize="10"/>
                                        <Button Command="{Binding DataContext.MoveCategoryDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding CategoryInfo}"
                                                Content="▼"
                                                Width="30"
                                                Height="30"
                                                Margin="2"
                                                ToolTip="Move Down"
                                                FontSize="10"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Category Content - Only visible when not collapsed -->
                                <ItemsControl Grid.Row="1" 
                                              ItemsSource="{Binding Inputs}"
                                              Padding="15"
                                              Visibility="{Binding CategoryInfo.IsCollapsed, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,15">
                                                <TextBlock Text="{Binding DisplayName}" 
                                                           FontWeight="SemiBold" 
                                                           Margin="0,0,0,5" 
                                                           Foreground="{DynamicResource TextBrush}"/>

                                                <!-- Single Line Text Input -->
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                                         Padding="5"
                                                         Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=text}"/>

                                                <!-- Multiline Text Input -->
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         MinHeight="60"
                                                         MaxHeight="200"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Padding="5"
                                                         FontFamily="Consolas"
                                                         FontSize="11"
                                                         Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=multiline}"/>

                                                <!-- Number Input -->
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                                         Padding="5"
                                                         Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=number}"/>

                                                <!-- Number Pair Input (Width x Height) -->
                                                <Grid Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=number_pair}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="100"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding Label1}" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource TextBrush}"/>
                                                    <TextBox Grid.Column="1" Text="{Binding Value1, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                                                    <TextBlock Grid.Column="2" Text="×" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{DynamicResource TextBrush}"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Label2}" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource TextBrush}"/>
                                                    <TextBox Grid.Column="4" Text="{Binding Value2, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                                                </Grid>

                                                <!-- Lora List -->
                                                <ItemsControl ItemsSource="{Binding Loras}"
                                                              Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=lora_list}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,5">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="150"/>
                                                                </Grid.ColumnDefinitions>

                                                                <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding LoraName}" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>

                                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                    <Slider Value="{Binding Strength}" Minimum="-2" Maximum="2" Width="80" VerticalAlignment="Center" 
                                                                            TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                                                                    <TextBox Text="{Binding Strength, StringFormat=F2}" Width="50" Margin="5,0,0,0" VerticalAlignment="Center" Padding="2"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>