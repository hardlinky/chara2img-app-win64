<UserControl x:Class="chara2img.Views.InputTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:chara2img"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <local:InputTypeToVisibilityConverter x:Key="InputTypeToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:CollapseIconConverter x:Key="CollapseIconConverter"/>
        
        <!-- Style to remove blue highlight from category header buttons -->
        <Style x:Key="CategoryHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#22000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#44000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Template for expanded category content -->
        <DataTemplate x:Key="CategoryContentTemplate">
            <ItemsControl ItemsSource="{Binding Inputs}" 
                          Padding="15"
                          Focusable="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,15">
                            <!-- Label with Variable Hint -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="{Binding DisplayName}" 
                                           FontWeight="SemiBold" 
                                           Foreground="{DynamicResource TextBrush}"/>
                                <!-- Primary Variable Hint -->
                                <TextBlock FontStyle="Italic" 
                                           FontSize="11"
                                           Foreground="#4A90E2"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Cursor="Hand"
                                           ToolTip="Click to copy to clipboard">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding VariableHint}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="TextDecorations" Value="Underline"/>
                                                    <Setter Property="Foreground" Value="#2171D6"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" 
                                                      Command="{Binding DataContext.CopyToClipboardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding VariableHint}"/>
                                    </TextBlock.InputBindings>
                                    <Run Text="{Binding VariableHint, Mode=OneWay}"/>
                                </TextBlock>
                                <!-- Named Variable Hint (alias) - Changed to blue -->
                                <TextBlock FontStyle="Italic" 
                                           FontSize="11"
                                           Foreground="#4A90E2"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Cursor="Hand"
                                           ToolTip="Click to copy to clipboard (alias based on Name field)">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NamedVariableHint}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="TextDecorations" Value="Underline"/>
                                                    <Setter Property="Foreground" Value="#2171D6"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" 
                                                      Command="{Binding DataContext.CopyToClipboardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding NamedVariableHint}"/>
                                    </TextBlock.InputBindings>
                                    <Run Text="{Binding NamedVariableHint, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Single Line Text Input -->
                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="5"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinLines="1"
                                     MaxLines="10"
                                     VerticalScrollBarVisibility="Auto"
                                     Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=text}"
                                     LostFocus="NameField_LostFocus"
                                     TextChanged="NameField_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Style.Triggers>
                                            <!-- Red border for validation errors -->
                                            <DataTrigger Binding="{Binding HasValidationError}" Value="True">
                                                <Setter Property="BorderBrush" Value="#F44336"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- Multiline Text Input -->
                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="60"
                                     MaxHeight="200"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="5"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=multiline}"/>

                            <!-- Number Input -->
                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="5"
                                     Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=number}"/>

                            <!-- Number Pair Input (Width x Height) -->
                            <Grid Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=number_pair}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Label1}" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource TextBrush}"/>
                                <TextBox Grid.Column="1" Text="{Binding Value1, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                                <TextBlock Grid.Column="2" Text="×" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Grid.Column="3" Text="{Binding Label2}" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource TextBrush}"/>
                                <TextBox Grid.Column="4" Text="{Binding Value2, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                            </Grid>

                            <!-- Boolean Input (Checkbox) -->
                            <CheckBox IsChecked="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                      VerticalAlignment="Center"
                                      Content=""
                                      Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=boolean}"/>

                            <!-- Lora List -->
                            <StackPanel Visibility="{Binding InputType, Converter={StaticResource InputTypeToVisibilityConverter}, ConverterParameter=lora_list}">
                                <!-- Add Lora Button -->
                                <Button Command="{Binding DataContext.AddLoraCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Content="+ Add Lora"
                                        HorizontalAlignment="Left"
                                        Padding="10,5"
                                        Margin="0,0,0,10"
                                        Background="#4CAF50"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"/>
                                
                                <!-- Lora Items -->
                                <ItemsControl ItemsSource="{Binding Loras}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0" 
                                                          IsChecked="{Binding Enabled}" 
                                                          VerticalAlignment="Center" 
                                                          Margin="0,0,10,0"/>
                                                
                                                <TextBox Grid.Column="1" 
                                                         Text="{Binding LoraName, UpdateSourceTrigger=PropertyChanged}" 
                                                         VerticalAlignment="Center"
                                                         Padding="5"
                                                         Margin="0,0,10,0"/>

                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                    <Slider Value="{Binding Strength}" 
                                                            Minimum="-2" 
                                                            Maximum="2" 
                                                            Width="80" 
                                                            VerticalAlignment="Center" 
                                                            TickFrequency="0.1" 
                                                            IsSnapToTickEnabled="True"/>
                                                    <TextBox Text="{Binding Strength, StringFormat=F2}" 
                                                             Width="50" 
                                                             Margin="5,0,0,0" 
                                                             VerticalAlignment="Center" 
                                                             Padding="2"/>
                                                </StackPanel>
                                                
                                                <!-- Remove Button -->
                                                <Button Grid.Column="3"
                                                        Command="{Binding DataContext.RemoveLoraCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="×"
                                                        Width="30"
                                                        Height="30"
                                                        Margin="5,0,0,0"
                                                        ToolTip="Remove Lora"
                                                        Background="#F44336"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        FontSize="16"
                                                        FontWeight="Bold"
                                                        Cursor="Hand"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DataTemplate>
    </UserControl.Resources>
    
    <Grid Margin="20" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Run Button at the top -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Command="{Binding RunJobCommand}"
                    Padding="20,10"
                    FontWeight="SemiBold"
                    Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="▶" 
                               Foreground="#00C853"
                               FontSize="14"
                               Margin="0,0,5,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Run ComfyUI Job" 
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Border Background="{DynamicResource AccentBrush}"
                    Padding="10,5"
                    CornerRadius="3"
                    Visibility="{Binding HasWorkflow, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <TextBlock Text="⚠ No workflow loaded"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold"/>
            </Border>
        </StackPanel>

        <!-- Scrollable inputs section -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding CategoryViewModels}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="1" 
                                CornerRadius="4" 
                                Margin="0,0,0,10"
                                Background="{DynamicResource WindowBackgroundBrush}">
                            <StackPanel>
                                <!-- Category Header -->
                                <Grid Background="#33000000">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Category Title (clickable to toggle) -->
                                    <Button Grid.Column="0" 
                                            Command="{Binding DataContext.ToggleCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding CategoryInfo}"
                                            Style="{StaticResource CategoryHeaderButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding CategoryInfo.IsCollapsed, Converter={StaticResource CollapseIconConverter}}"
                                                       FontFamily="Segoe UI Symbol"
                                                       FontSize="14"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <TextBlock Text="{Binding CategoryInfo.Name}" 
                                                       FontWeight="Bold" 
                                                       FontSize="14"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Reorder Buttons -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="5">
                                        <Button Command="{Binding DataContext.MoveCategoryUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding CategoryInfo}"
                                                Content="▲"
                                                Width="30"
                                                Height="30"
                                                Margin="2"
                                                ToolTip="Move Up"
                                                FontSize="10"/>
                                        <Button Command="{Binding DataContext.MoveCategoryDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding CategoryInfo}"
                                                Content="▼"
                                                Width="30"
                                                Height="30"
                                                Margin="2"
                                                ToolTip="Move Down"
                                                FontSize="10"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Category Content - ONLY render when NOT collapsed -->
                                <ContentControl>
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Setter Property="Content" Value="{x:Null}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CategoryInfo.IsCollapsed}" Value="False">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource CategoryContentTemplate}"/>
                                                    <Setter Property="Content" Value="{Binding}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>